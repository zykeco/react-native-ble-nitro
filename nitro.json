{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["co", "zyke", "ble"],
  "ios": {
    "iosModuleName": "BleNitro"
  },
  "android": {
    "androidNamespace": ["co", "zyke", "ble"],
    "androidCxxLibName": "BleNitro"
  },
  "autolinking": {
    "NativeBleNitro": {
      "ios": {
        "language": "swift",
        "implementationClassName": "BleNitroBleManager"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "BleNitroBleManager"
      }
    },
    "NativeBleNitroFactory": {
      "ios": {
        "language": "swift",
        "implementationClassName": "BleNitroBleManagerFactory"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "BleNitroBleManagerFactory"
      }
    }
  },
  "ignorePaths": ["**/node_modules", "**/android/build"],
  "gitAttributesGeneratedFlag": true
}
